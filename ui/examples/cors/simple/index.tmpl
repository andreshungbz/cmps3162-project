<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF=8" />
  </head>
  <body>
    <h1>Hotel Room Booking & HouseKeeping Management</h1>
    <h2>Simple CORS Example</h2>
    <p>
      In this example, we get a CORS error if we do not configure our server
      with trusted origins.
    </p>
    <div id="output"></div>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        fetch('http://localhost:4000/v1/healthcheck').then(
          function (response) {
            response.text().then(function (text) {
              document.getElementById('output').innerHTML = text;
            });
          },
          function (err) {
            document.getElementById('output').innerHTML = err;
          },
        );
      });
    </script>
  </body>
</html>
